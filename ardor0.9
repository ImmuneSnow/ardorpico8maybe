-- ARDOR v0.9
-- globals
local px,py       = 64,64
local speed       = 1
local trail       = {}
local trail_len   = 4

local mx,my       = 0,0
local facing      = 0

local stab_len    = 9
local stab_active = false
local stab_timer  = 0
local stab_cd     = 8
local ray_x,ray_y = 0,0

local prev_click  = false
local shake_t     = 0
local shake_x     = 0
local shake_y     = 0

local gen_chance  = 0.25
local cull_r      = 45
local walls       = {}

local enemies     = {}

local wave        = 1
local wave_timer  = 300
local wave_flash  = 0
local spawn_timer = 60

local score       = 0
local score_flash = 0

local downed      = false
local down_timer  = 120
local down_presses= 0
local down_needed = 15
local prev_dirs   = {false,false,false,false}
local inv_timer   = 0

-- helpers
local function sq_dist(ax,ay,bx,by)
    local dx=ax-bx local dy=ay-by return dx*dx+dy*dy
end

-- init
function _init()
    poke(0x5f2d,1)
    poke(0x5f2e,1)
end

-- wall generation
function update_walls()
    for i=#walls,1,-1 do
        local w=walls[i]
        if sq_dist(w.x+w.w/2,w.y+w.h/2,px,py) > cull_r*cull_r then
            del(walls,walls[i])
        end
    end

    if rnd(1)<gen_chance then
        local a=rnd(1)
        local d=10+rnd(15)
        local wx=max(2,min(124,px+cos(a)*d))
        local wy=max(2,min(124,py+sin(a)*d))
        local sizes={{w=12,h=4},{w=4,h=12},{w=8,h=4},{w=4,h=8},{w=6,h=6},{w=4,h=4}}
        local s=sizes[flr(rnd(#sizes))+1]
        local ok=true
        for w in all(walls) do
            if wx<w.x+w.w+8 and wx+s.w>w.x-8 and
               wy<w.y+w.h+8 and wy+s.h>w.y-8 then
                ok=false break
            end
        end
        if ok and sq_dist(wx,wy,px,py)>=256 then
            add(walls,{x=wx,y=wy,w=s.w,h=s.h})
        end
    end
end

-- wave + spawning
function update_wave()
    wave_timer-=1
    if wave_timer<=0 then
        wave+=1
        wave_flash=30
        wave_timer=min(1200,300+wave*60)
        spawn_timer=60
    end

    spawn_timer-=1
    if spawn_timer<=0 then
        spawn_timer=max(8,50-wave*5)
        local count=wave<3 and 1 or 2
        for i=1,count do
            local a=rnd(1)
            local d=18+rnd(12)
            local ex=max(2,min(125,px+cos(a)*d))
            local ey=max(2,min(125,py+sin(a)*d))
            local ok=true
            for w in all(walls) do
                if ex>=w.x-2 and ex<=w.x+w.w+2 and
                   ey>=w.y-2 and ey<=w.y+w.h+2 then
                    ok=false break
                end
            end
            if ok then
                local etype=rnd(1)<0.75 and "chase" or "flee"
                add(enemies,{x=ex,y=ey,alive=true,etype=etype})
            end
        end
    end
end

-- enemy ai
function update_enemies()
    for e in all(enemies) do
        if e.alive then
            local dx=px-e.x
            local dy=py-e.y
            local dist=sqrt(dx*dx+dy*dy)
            if e.etype=="flee" and dist>cull_r then
                e.alive=false
            elseif dist>0 then
                local spd=e.etype=="chase" and 0.5 or -0.6
                e.x+=dx/dist*spd
                e.y+=dy/dist*spd
            end
            if sq_dist(e.x,e.y,px,py)<9 and not downed and inv_timer<=0 then
                downed=true
                down_timer=120
                down_presses=0
                down_needed=15+wave
            end
        else
            del(enemies,e)
        end
    end
end

-- downed minigame
function update_downed()
    down_timer-=1

    for i=0,3 do
        local held=btn(i)
        if held and not prev_dirs[i+1] then
            down_presses+=1
            shake_t=6
        end
        prev_dirs[i+1]=held
    end

    if down_presses>=down_needed then
        downed=false
        down_presses=0
        shake_t=0
        inv_timer=90
    elseif down_timer<=0 then
        downed=false
        down_presses=0
        score=0
        wave=1
        wave_timer=300
        spawn_timer=60
    end
end

-- update
function _update()
    update_walls()
    update_wave()
    update_enemies()

    mx,my=stat(32),stat(33)

    if inv_timer>0 then inv_timer-=1 end

    if downed then
        update_downed()
        if shake_t>0 then
            shake_x=flr(rnd(3))-1
            shake_y=flr(rnd(3))-1
            shake_t-=0.5
        else
            shake_x,shake_y=0,0
        end
        if wave_flash>0  then wave_flash-=1  end
        if score_flash>0 then score_flash-=1 end
        return
    end

    -- movement
    local nx,ny=px,py
    if btn(0) then nx-=speed end
    if btn(1) then nx+=speed end
    if btn(2) then ny-=speed end
    if btn(3) then ny+=speed end

    local bx,by=false,false
    for w in all(walls) do
        if nx-1<w.x+w.w and nx+2>w.x and py-1<w.y+w.h and py+2>w.y then bx=true end
        if px-1<w.x+w.w and px+2>w.x and ny-1<w.y+w.h and ny+2>w.y then by=true end
    end
    if not bx then px=nx end
    if not by then py=ny end
    px=max(2,min(125,px))
    py=max(2,min(125,py))

    -- trail
    add(trail,{x=px,y=py})
    if #trail>trail_len then
        for i=1,#trail-1 do trail[i]=trail[i+1] end
        trail[#trail]=nil
    end

    -- ray (wall-clipped)
    facing=atan2(py-my,mx-px)
    local dx=mx-px
    local dy=my-py
    local dist=sqrt(dx*dx+dy*dy)
    ray_x,ray_y=px,py
    if dist>0 then
        local nx=dx/dist
        local ny=dy/dist
        for i=1,min(dist,stab_len) do
            local tx=px+nx*i
            local ty=py+ny*i
            local hit=false
            for w in all(walls) do
                if tx>=w.x and tx<=w.x+w.w and
                   ty>=w.y and ty<=w.y+w.h then
                    hit=true break
                end
            end
            if hit then break end
            ray_x,ray_y=tx,ty
        end
    end

    -- screenshake
    if shake_t>0 then
        shake_x=flr(rnd(3))-1
        shake_y=flr(rnd(3))-1
        shake_t-=0.5
    else
        shake_x,shake_y=0,0
    end

    -- stab input
    local clicking=stat(34)&0x1!=0
    local just_clicked=clicking and not prev_click
    prev_click=clicking

    if (btnp(4) or just_clicked) and stab_timer<=0 then
        stab_active=true
        stab_timer=stab_cd
        trail={}
    end

    stab_timer=max(0,stab_timer-1)
    if stab_timer<=0 then stab_active=false end

    -- stab hit detection
    if stab_active then
        local rdx=ray_x-px
        local rdy=ray_y-py
        local rdist=sqrt(rdx*rdx+rdy*rdy)
        if rdist>0 then
            local nx=rdx/rdist
            local ny=rdy/rdist
            for e in all(enemies) do
                if e.alive then
                    for i=1,stab_len do
                        local tx=px+nx*i
                        local ty=py+ny*i
                        if sq_dist(e.x,e.y,tx,ty)<9 then
                            e.alive=false
                            score+=e.etype=="chase" and 5 or 10
                            score_flash=8
                            shake_t=4
                            break
                        end
                    end
                end
            end
        end
    end

    if wave_flash>0  then wave_flash-=1  end
    if score_flash>0 then score_flash-=1 end
end

-- draw
function _draw()
    cls()
    camera(shake_x,shake_y)

    -- walls
    for w in all(walls) do
        local cx=w.x+w.w/2
        local cy=w.y+w.h/2
        local d=sqrt(sq_dist(cx,cy,px,py))
        local dot=(ray_x-px)*(cx-px)+(ray_y-py)*(cy-py)
        local c
        if     d>30  then c=1
        elseif d>25  then c=129
        elseif dot>0 then c=140
        else              c=129
        end
        rectfill(w.x,w.y,w.x+w.w,w.y+w.h,c)
    end

    -- enemies
    for e in all(enemies) do
        if e.alive then
            rectfill(e.x-1,e.y-1,e.x+1,e.y+1,e.etype=="chase" and 8 or 12)
        end
    end

    -- trail
    for i=1,#trail do
        local t=trail[i]
        rectfill(t.x-1,t.y-1,t.x+1,t.y+1,min(4+i,7))
    end

    -- ray + player
    line(px,py,ray_x,ray_y,stab_active and 7 or 8)

    local pc
    if downed then
        pc=(t()%0.1<0.05) and 12 or 1
    elseif inv_timer>0 then
        pc=(inv_timer%4<2) and 12 or 7
    elseif stab_active then
        pc=stab_timer%2==0 and 7 or 8
    else
        pc=7
    end
    rectfill(px-1,py-1,px+1,py+1,pc)

    -- downed ui
    if downed then
        local bw=flr((down_presses/down_needed)*60)
        rectfill(34,60,94,66,1)
        rectfill(34,60,34+bw,66,12)
        rect(34,60,94,66,7)
        print("stay",56,68,12)
    end

    -- border (camera-locked)
    camera()
    local bc=wave_flash>0 and (wave_flash%4<2 and 7 or 1) or 1
    rect(0,0,127,127,bc)
    camera(shake_x,shake_y)

    -- cursor
    spr(0,mx-4,my-4)

    -- hud
    camera()
    local sc=score_flash>0 and (score_flash%2==0 and 7 or 10) or 7
    print(score,2,2,sc)
    print("w"..wave,61,2,7)
end
