-- ARDOR v0.7
-- globals
local px, py = 64, 64
local speed = 1
local trail, trail_len = {}, 4

local mx, my = 0, 0
local facing = 0

local stab_len = 9
local stab_active = false
local stab_timer, stab_cd = 0, 8
local ray_x, ray_y = 0, 0

local prev_click = false
local shake_t = 0
local shake_x, shake_y = 0, 0

local gen_chance = 0.25
local cull_r = 45

local dummy = {x=96, y=64, alive=true}

-- init
function _init()
    poke(0x5f2d, 1)
    poke(0x5f2e, 1)
    walls = {}
end

-- wall generation
function update_walls()
    for i = #walls, 1, -1 do
        local w = walls[i]
        local dx = (w.x+w.w/2) - px
        local dy = (w.y+w.h/2) - py
        if sqrt(dx*dx+dy*dy) > cull_r then
            del(walls, walls[i])
        end
    end

    if rnd(1) < gen_chance then
        local a = rnd(1)
        local d = 10 + rnd(15)
        local wx = max(2, min(124, px + cos(a)*d))
        local wy = max(2, min(124, py + sin(a)*d))

        local sizes = {{w=12,h=4},{w=4,h=12},{w=8,h=4},{w=4,h=8},{w=6,h=6}}
        local s = sizes[flr(rnd(#sizes))+1]

        local ok = true
        for w in all(walls) do
            if wx < w.x+w.w+8 and wx+s.w > w.x-8 and
               wy < w.y+w.h+8 and wy+s.h > w.y-8 then
                ok = false break
            end
        end
        if ok and sqrt((wx-px)^2+(wy-py)^2) >= 16 then
            add(walls, {x=wx, y=wy, w=s.w, h=s.h})
        end
    end
end

-- update
function _update()
    update_walls()

    mx, my = stat(32), stat(33)

    -- movement + collision
    local nx, ny = px, py
    if btn(0) then nx -= speed end
    if btn(1) then nx += speed end
    if btn(2) then ny -= speed end
    if btn(3) then ny += speed end

    local bx, by = false, false
    for w in all(walls) do
        if nx-1 < w.x+w.w and nx+2 > w.x and py-1 < w.y+w.h and py+2 > w.y then bx = true end
        if px-1 < w.x+w.w and px+2 > w.x and ny-1 < w.y+w.h and ny+2 > w.y then by = true end
    end
    if not bx then px = nx end
    if not by then py = ny end

    px = max(2, min(125, px))
    py = max(2, min(125, py))

    -- trail
    add(trail, {x=px, y=py})
    if #trail > trail_len then
        for i=1, #trail-1 do trail[i]=trail[i+1] end
        trail[#trail] = nil
    end

    -- ray
    facing = atan2(py-my, mx-px)
    local dx = mx-px
    local dy = my-py
    local dist = sqrt(dx*dx+dy*dy)
    if dist > 0 then
        local nx = dx/dist
        local ny = dy/dist
        local len = min(dist, stab_len)
        ray_x, ray_y = px, py
        for i=1, len do
            local tx = px + nx*i
            local ty = py + ny*i
            local hit = false
            for w in all(walls) do
                if tx >= w.x and tx <= w.x+w.w and
                   ty >= w.y and ty <= w.y+w.h then
                    hit = true break
                end
            end
            if hit then break end
            ray_x, ray_y = tx, ty
        end
    else
        ray_x, ray_y = px, py
    end

    -- shake
    if shake_t > 0 then
        shake_x = flr(rnd(3))-1
        shake_y = flr(rnd(3))-1
        shake_t -= 0.5
    else
        shake_x, shake_y = 0, 0
    end

    -- stab input
    local clicking = stat(34)&0x1 != 0
    local just_clicked = clicking and not prev_click
    prev_click = clicking

    if (btnp(4) or just_clicked) and stab_timer <= 0 then
        stab_active = true
        stab_timer = stab_cd
        trail = {}
        shake_t = 4
    end

    stab_timer = max(0, stab_timer-1)
    if stab_timer <= 0 then stab_active = false end

    -- dummy hit
    if stab_active and dummy.alive then
        local ex = dummy.x - ray_x
        local ey = dummy.y - ray_y
        if sqrt(ex*ex+ey*ey) < 4 then dummy.alive = false end
    end
end

-- draw
function _draw()
    cls()
    camera(shake_x, shake_y)

    -- walls with distance shading
    for w in all(walls) do
        local cx = w.x+w.w/2
        local cy = w.y+w.h/2
        local d = sqrt((cx-px)^2+(cy-py)^2)
        local dot = (ray_x-px)*(cx-px) + (ray_y-py)*(cy-py)
        local c
        if d > 30 then c = 1
        elseif d > 25 then c = 129
        elseif dot > 0 then c = 140
        else c = 129
        end
        rectfill(w.x, w.y, w.x+w.w, w.y+w.h, c)
    end

    -- dummy
    if dummy.alive then
        rectfill(dummy.x-1, dummy.y-1, dummy.x+1, dummy.y+1, 8)
    end

    -- trail
    for i=1, #trail do
        local t = trail[i]
        local c = min(4+i, 7)
        rectfill(t.x-1, t.y-1, t.x+1, t.y+1, c)
    end

    -- ray
    line(px, py, ray_x, ray_y, stab_active and 7 or 8)

    -- player
    local pc = 7
    if stab_active then pc = (stab_timer%2==0) and 7 or 8 end
    rectfill(px-1, py-1, px+1, py+1, pc)

    -- border
    rect(0, 0, 127, 127, 1)

    -- cursor
    spr(0, mx-4, my-4)
end
